# Configuration for feature/mocks branch

# Mock all external integrations (Trello, Slack, SendGrid)
MOCK_INTEGRATIONS=true

# Use real Medusa.js repository for code-context triage
MEDUSA_REPO_PATH=./medusa-repo

# Database (use SQLite locally)
DATABASE_URL=sqlite:///./data/incidents.db

# Mock API keys (not used when MOCK_INTEGRATIONS=true)
TRELLO_API_KEY=mock-key-12345
TRELLO_API_TOKEN=mock-token-67890
TRELLO_BOARD_ID=mock-board-id
TRELLO_LIST_ID=mock-list-id
TRELLO_DONE_LIST_ID=mock-done-list-id

# Module -> owner routing for Trello assignment + Slack mention
OWNER_ROUTING_JSON={"cart":{"trello_member_id":"mock-member-cart","slack_user_id":"U_MOCK_CART"},"payment":{"trello_member_id":"mock-member-payment","slack_user_id":"U_MOCK_PAYMENT"},"default":{"trello_member_id":"mock-member-oncall","slack_user_id":"U_MOCK_ONCALL"}}

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/MOCK/MOCK/MOCK
SLACK_CHANNEL=#mock-incidents

SENDGRID_API_KEY=SG.mock-key-1234567890
SENDGRID_FROM_EMAIL=mock-sre@example.com
SENDGRID_FROM_NAME=Mock SRE Agent

# LLM still uses real Anthropic API (but you can mock this too)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Development
DEBUG=true
LOG_LEVEL=debug

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Resolution watcher
RESOLUTION_WATCHER_INTERVAL_SECONDS=30
