# SRE Incident Intake & Triage Agent — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# =============================================================================
# LLM — Anthropic (required)
# =============================================================================
# Get your API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# Ticketing — Trello (required unless MOCK_INTEGRATIONS=true)
# =============================================================================
# Get API key and token at: https://trello.com/app-key
TRELLO_API_KEY=your-trello-api-key-here
TRELLO_API_TOKEN=your-trello-api-token-here

# Board ID: found in the Trello board URL: trello.com/b/{BOARD_ID}/board-name
TRELLO_BOARD_ID=your-trello-board-id-here

# List ID for new incidents (e.g., "To Do" column)
# Get via: curl "https://api.trello.com/1/boards/{BOARD_ID}/lists?key={KEY}&token={TOKEN}"
TRELLO_LIST_ID=your-todo-list-id-here

# List ID for resolved incidents (e.g., "Done" column)
TRELLO_DONE_LIST_ID=your-done-list-id-here

# Owner routing by affected module (JSON)
# Keys should match triage modules: cart, order, payment, inventory, product,
# customer, shipping, discount, unknown, default
# - trello_member_id: Trello member to assign card owner
# - slack_user_id: Slack user to mention in incident alerts
OWNER_ROUTING_JSON={"cart":{"trello_member_id":"member_id_cart","slack_user_id":"U01234567"},"payment":{"trello_member_id":"member_id_payment","slack_user_id":"U07654321"},"default":{"trello_member_id":"member_id_oncall","slack_user_id":"U00000000"}}

# =============================================================================
# Communicator — Slack (required unless MOCK_INTEGRATIONS=true)
# =============================================================================
# Create an Incoming Webhook at: https://api.slack.com/apps
# Select your workspace, choose the #incidents channel
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =============================================================================
# Email (optional — set MOCK_EMAIL=true if no SendGrid account)
# =============================================================================
# Get API key at: https://sendgrid.com (free tier available)
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# From address and name for outgoing emails
SENDGRID_FROM_EMAIL=sre-agent@yourcompany.com
SENDGRID_FROM_NAME=SRE Agent

# =============================================================================
# Database
# =============================================================================
# SQLite (default, no external service needed)
DATABASE_URL=sqlite:///./data/incidents.db

# PostgreSQL (for production scaling):
# DATABASE_URL=postgresql://user:password@host:5432/sre_incidents

# =============================================================================
# Application
# =============================================================================
APP_PORT=3000
LOG_LEVEL=INFO

# Path to persistent log file (inside container, mounted as Docker volume)
LOG_FILE=/app/logs/agent.log

# =============================================================================
# E-commerce Codebase (Medusa.js)
# =============================================================================
# Path inside the Docker container where Medusa.js is cloned
# This is set automatically during Docker build — do not change unless customizing the Dockerfile
ECOMMERCE_REPO_PATH=/app/medusa-repo

# =============================================================================
# Demo / Development Mode
# =============================================================================
# Set to true to skip ALL real API calls (Trello, Slack, email)
# All external calls return realistic simulated responses
# Logs show "mock": true in observability events
MOCK_INTEGRATIONS=false

# =============================================================================
# Resolution Watcher
# =============================================================================
# How often (in seconds) to poll Trello for resolved cards
RESOLUTION_WATCHER_INTERVAL_SECONDS=60

