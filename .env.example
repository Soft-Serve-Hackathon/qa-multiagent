# =============================================================================
# SRE Incident Triage Agent — Plantilla de configuración
# =============================================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Elige el modo de operación (MOCK o REAL) y ajusta las variables
# 3. Nunca hacer commit de .env con credenciales reales
#
# MOCK MODE  → MOCK_INTEGRATIONS=true  → no se necesitan credenciales externas
# REAL MODE  → MOCK_INTEGRATIONS=false → requiere Trello, Slack, SendGrid reales
# =============================================================================


# =============================================================================
# MODO ACTIVO
# =============================================================================
MOCK_INTEGRATIONS=true   # cambiar a false para usar integraciones reales


# =============================================================================
# LLM — Anthropic (SIEMPRE requerido)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here   # https://console.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-6


# =============================================================================
# TRELLO
# =============================================================================

# ── MOCK MODE (valores de ejemplo, se ignoran cuando MOCK_INTEGRATIONS=true) ──
TRELLO_API_KEY=mock-key-12345
TRELLO_API_TOKEN=mock-token-67890
TRELLO_BOARD_ID=mock-board-id
TRELLO_LIST_ID=mock-list-id
TRELLO_DONE_LIST_ID=mock-done-list-id

# ── REAL MODE (descomenta y llena cuando MOCK_INTEGRATIONS=false) ─────────────
# Credenciales: https://trello.com/app-key
# TRELLO_API_KEY=tu-api-key-real
# TRELLO_API_TOKEN=tu-api-token-real
# TRELLO_BOARD_ID=id-del-board       # en URL: trello.com/b/{BOARD_ID}/nombre
# TRELLO_LIST_ID=id-columna-todo     # curl "...api.trello.com/1/boards/{ID}/lists?key=...&token=..."
# TRELLO_DONE_LIST_ID=id-columna-done


# =============================================================================
# SLACK
# =============================================================================

# ── MOCK MODE ─────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/MOCK/MOCK/MOCK
SLACK_CHANNEL=#incidents

# ── REAL MODE ─────────────────────────────────────────────────────────────────
# Crear Incoming Webhook: https://api.slack.com/apps → tu workspace → #incidents
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TU/REAL/WEBHOOK
# SLACK_CHANNEL=#incidents


# =============================================================================
# EMAIL — SendGrid
# =============================================================================

# ── MOCK MODE ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.mock-key-placeholder
SENDGRID_FROM_EMAIL=sre-agent@example.com
SENDGRID_FROM_NAME=SRE Agent

# ── REAL MODE ─────────────────────────────────────────────────────────────────
# https://sendgrid.com (free tier disponible)
# SENDGRID_API_KEY=SG.tu-api-key-real
# SENDGRID_FROM_EMAIL=sre-agent@tuempresa.com
# SENDGRID_FROM_NAME=SRE Agent


# =============================================================================
# OWNER ROUTING — asignación por módulo afectado
# =============================================================================
# Mapea módulo → miembro Trello + usuario Slack
# IDs Trello: GET /1/boards/{ID}/members?key=...&token=...
# IDs Slack:  perfil del usuario → "Copy member ID"

# ── MOCK MODE ─────────────────────────────────────────────────────────────────
OWNER_ROUTING_JSON={"cart":{"trello_member_id":"mock-member-cart","slack_user_id":"U_MOCK_CART"},"payment":{"trello_member_id":"mock-member-payment","slack_user_id":"U_MOCK_PAYMENT"},"default":{"trello_member_id":"mock-member-oncall","slack_user_id":"U_MOCK_ONCALL"}}

# ── REAL MODE ─────────────────────────────────────────────────────────────────
# OWNER_ROUTING_JSON={"cart":{"trello_member_id":"abc123","slack_user_id":"U012345"},"payment":{"trello_member_id":"def456","slack_user_id":"U678901"},"default":{"trello_member_id":"ghi789","slack_user_id":"U234567"}}


# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///./data/incidents.db

# PostgreSQL (para escalar en producción):
# DATABASE_URL=postgresql://user:password@host:5432/sre_incidents


# =============================================================================
# E-COMMERCE CODEBASE — Medusa.js
# =============================================================================
MEDUSA_REPO_PATH=./medusa-repo


# =============================================================================
# APLICACIÓN
# =============================================================================
DEBUG=false
LOG_LEVEL=info
LOG_FILE=/app/logs/agent.log

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Frecuencia de polling a Trello para detectar incidentes resueltos (segundos)
RESOLUTION_WATCHER_INTERVAL_SECONDS=60
