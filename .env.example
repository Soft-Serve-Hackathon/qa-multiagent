# =============================================================================
# SRE Incident Triage Agent — Plantilla de configuración
# =============================================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Elige el modo de operación y llena las variables correspondientes
# 3. NUNCA hacer commit de .env con credenciales reales
#
# MOCK MODE  → MOCK_INTEGRATIONS=true  → no se necesitan credenciales externas
# REAL MODE  → MOCK_INTEGRATIONS=false → requiere Trello + Anthropic (mínimo)
# =============================================================================

# =============================================================================
# MODO ACTIVO
# =============================================================================
MOCK_INTEGRATIONS=true

# =============================================================================
# LLM — Anthropic (SIEMPRE requerido, incluso en mock mode)
# Obtener key: https://console.anthropic.com
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# TRELLO (requerido cuando MOCK_INTEGRATIONS=false)
# Credenciales: https://trello.com/app-key
# Board/List IDs: GET /1/boards/{ID}/lists?key=...&token=...
# =============================================================================
TRELLO_API_KEY=mock-key-12345
TRELLO_API_TOKEN=mock-token-67890
TRELLO_BOARD_ID=mock-board-id
TRELLO_LIST_ID=mock-list-id
TRELLO_DONE_LIST_ID=mock-done-list-id

# =============================================================================
# SLACK (opcional — falla silenciosa si es placeholder)
# Crear Incoming Webhook: https://api.slack.com/apps → tu workspace → #incidents
# =============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/MOCK/MOCK/MOCK
SLACK_CHANNEL=#incidents

# =============================================================================
# EMAIL — SendGrid (opcional — falla silenciosa si clave es placeholder)
# Free tier: https://sendgrid.com
# =============================================================================
SENDGRID_API_KEY=SG.mock-key-placeholder
SENDGRID_FROM_EMAIL=sre-agent@example.com
SENDGRID_FROM_NAME=SRE Agent

# =============================================================================
# OWNER ROUTING — asignación automática por módulo (opcional)
# Mapea módulo → miembro Trello + usuario Slack
# IDs Trello: GET /1/boards/{ID}/members?key=...&token=...
# IDs Slack:  perfil del usuario → "Copy member ID"
# Dejar {} para deshabilitar la asignación automática
# =============================================================================
OWNER_ROUTING_JSON={}

# =============================================================================
# BASE DE DATOS
# =============================================================================
DATABASE_URL=sqlite:///./data/incidents.db

# =============================================================================
# CODEBASE E-COMMERCE — Medusa.js
# En Docker el repo se clona en /app/medusa-repo durante el build
# =============================================================================
ECOMMERCE_REPO_PATH=/app/medusa-repo

# =============================================================================
# APLICACIÓN
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=/app/logs/agent.log
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# =============================================================================
# RESOLUTION WATCHER
# =============================================================================
RESOLUTION_WATCHER_INTERVAL_SECONDS=60
