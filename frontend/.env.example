# Next.js Frontend Environment Variables
# Copy this to .env.local for development
# NEXT_PUBLIC_* variables are exposed to the browser

# Backend API URL (used in next.config.js for rewrites)
# In docker-compose, this should be http://backend:8000/api
# In development (localhost), this should be http://localhost:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Optional: Backend API URL for server-side operations (not exposed to browser)
API_URL=http://backend:8000/api
